# MongoDB Connection String
# Get this from MongoDB Atlas after creating a cluster
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/fraud_detection?retryWrites=true&w=majority

# For local MongoDB (if you have it installed locally)
# MONGODB_URL=mongodb://localhost:27017

# IBM Quantum Token (optional - only if using real quantum hardware)
IBM_QUANTUM_TOKEN=your_token_here
